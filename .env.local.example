# Neon Postgres
DATABASE_URL="postgresql://<user>:<pwd>@<endpoint>.neon.tech/<db>?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://<user>:<pwd>@<endpoint>.neon.tech/<db>?sslmode=require"

# Auth.js v5
AUTH_SECRET="<openssl rand -base64 32>"
AUTH_URL="https://<ton-app>.vercel.app"

# SSO Microsoft Entra ID (Jalon 5)
AUTH_MICROSOFT_ENTRA_ID_ID="<client-id>"
AUTH_MICROSOFT_ENTRA_ID_SECRET="<client-secret>"
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/<tenant-id>/v2.0"

# Pusher Channels (cluster eu, présence activée)
PUSHER_APP_ID="..."
PUSHER_SECRET="..."
NEXT_PUBLIC_PUSHER_KEY="..."
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# Resend (emails transactionnels)
RESEND_API_KEY="re_..."
EMAIL_FROM="Klint Planning <planning@klint-consulting.com>"

# App
NEXT_PUBLIC_APP_URL="https://<ton-app>.vercel.app"
